<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="White Noise"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switchRain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rain" />

        <SeekBar
            android:id="@+id/seekRain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Switch
            android:id="@+id/switchOcean"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ocean" />

        <SeekBar
            android:id="@+id/seekOcean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnTimer10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set 10 min sleep timer" />

        <Button
            android:id="@+id/btnStopAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop all sounds" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Timer: not set" />

    </LinearLayout>
</ScrollView>